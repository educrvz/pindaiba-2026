# OpenWA
OPENWA_API_KEY=change-me-long-random-string
OPENWA_IMAGE=ghcr.io/rmyndharis/openwa:latest

# Webhook receiver
WEBHOOK_SECRET=change-me-another-long-random-string
SIGNATURE_HEADER=x-openwa-signature

# Notion automation (optional — leave blank to disable)
# Database must have at least: Name (title), Phone (text), Last message (text), Source (select)
NOTION_TOKEN=
NOTION_LEADS_DATABASE_ID=
